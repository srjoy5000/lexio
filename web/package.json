{
  "name": "lexio-web",
  "version": "1.0.0",
  "description": "Frontend for Lexio",
  "type": "module",
  "scripts": {
    "predev": "lsof -ti:3001 | xargs kill -9 || true",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "dexie": "^4.2.0",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^0.282.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.16",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
